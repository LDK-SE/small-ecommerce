{
  "name": "small-ecommerce-api",
  "version": "1.0.0",
  "description": "Small ecommerce backend built with Node.js, Express, MongoDB, Mongoose, and JWT.",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed/products.js",
    "seed:reviews": "node seed/reviews.js",
    "client:dev": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client",
    "mobile:start": "npm run start --prefix mobile",
    "mobile:android": "npm run android --prefix mobile",
    "mobile:ios": "npm run ios --prefix mobile"
  },
  "keywords": [
    "node",
    "express",
    "mongodb",
    "mongoose",
    "jwt",
    "ecommerce"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.1",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
